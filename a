<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Neosert Agency</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white text-gray-900">

  <!-- Navbar -->
  <header class="bg-white shadow fixed w-full z-50">
    <div class="relative h-[80px] flex items-center justify-between px-[60px]">
      <img src="images/logo.png" alt="Neosert Logo" class="w-[120px] h-[40px]">
      <nav class="flex space-x-[40px]">
        <a href="#home" class="hover:text-green-600">Home</a>
        <a href="#pages" class="hover:text-green-600">Pages</a>
        <a href="#services" class="hover:text-green-600">Services</a>
        <a href="#portfolio" class="hover:text-green-600">Portfolio</a>
        <a href="#blog" class="hover:text-green-600">Blog</a>
      </nav>
      <a href="#contact" class="bg-green-600 text-white px-[24px] py-[12px] rounded-lg hover:bg-green-700">Get Started</a>
    </div>
  </header>

  <!-- Hero Section -->
  <section id="home" class="relative bg-gray-50 h-[700px]">
    <div class="absolute top-[160px] left-[100px] w-[500px]">
      <h1 class="text-[48px] font-bold leading-tight mb-[24px]">Lessons and insights from 8 years</h1>
      <p class="text-[18px] mb-[32px]">Where to grow your business as a photographer: site or social media?</p>
      <a href="#about" class="bg-green-600 text-white px-[32px] py-[16px] rounded-lg hover:bg-green-700">Learn More</a>
    </div>
    <img src="images/hero-illustration.png" alt="Hero Illustration" class="absolute top-[120px] right-[100px] w-[500px] h-[400px]">
  </section>

  <!-- Clients Section -->
  <section id="clients" class="relative bg-white h-[200px]">
    <h2 class="absolute top-[40px] left-1/2 transform -translate-x-1/2 text-[24px] font-bold">Our Clients</h2>
    <div class="absolute bottom-[40px] left-1/2 transform -translate-x-1/2 flex space-x-[40px]">
      <img src="images/client1.png" alt="Client 1" class="w-[100px] h-[40px]">
      <img src="images/client2.png" alt="Client 2" class="w-[100px] h-[40px]">
      <img src="images/client3.png" alt="Client 3" class="w-[100px] h-[40px]">
      <img src="images/client4.png" alt="Client 4" class="w-[100px] h-[40px]">
      <img src="images/client5.png" alt="Client 5" class="w-[100px] h-[40px]">
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="relative bg-gray-50 h-[600px]">
    <h2 class="absolute top-[60px] left-1/2 transform -translate-x-1/2 text-[32px] font-bold">Manage your entire community in a single system</h2>
    <div class="absolute top-[160px] left-1/2 transform -translate-x-1/2 grid grid-cols-3 gap-[40px]">
      <div class="bg-white shadow-lg w-[300px] h-[300px] p-[24px] rounded-lg text-center">
        <img src="images/membership.png" alt="Membership" class="mx-auto mb-[16px] w-[64px] h-[64px]">
        <h3 class="text-[20px] font-semibold mb-[12px]">Membership Organization</h3>
        <p class="text-[14px]">Unify your members and manage them effectively.</p>
      </div>
      <div class="bg-white shadow-lg w-[300px] h-[300px] p-[24px] rounded-lg text-center">
        <img src="images/association.png" alt="Association" class="mx-auto mb-[16px] w-[64px] h-[64px]">
        <h3 class="text-[20px] font-semibold mb-[12px]">National Associations</h3>
        <p class="text-[14px]">Streamline operations for large associations.</p>
      </div>
      <div class="bg-white shadow-lg w-[300px] h-[300px] p-[24px] rounded-lg text-center">
        <img src="images/clubs.png" alt="Clubs" class="mx-auto mb-[16px] w-[64px] h-[64px]">
        <h3 class="text-[20px] font-semibold mb-[12px]">Clubs And Groups</h3>
        <p class="text-[14px]">Bring communities together with ease.</p>
      </div>
    </div>
  </section>

  <!-- Case Study -->
  <section id="case-study" class="relative bg-white h-[600px]">
    <img src="images/case1.png" alt="Case Study" class="absolute top-[100px] left-[100px] w-[400px] h-[300px] rounded-lg shadow-lg">
    <div class="absolute top-[100px] right-[100px] w-[500px]">
      <h3 class="text-[32px] font-bold mb-[24px]">The unseen of spending three years at Phospagraph</h3>
      <p class="mb-[24px] text-[16px]">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.</p>
      <a href="#" class="bg-green-600 text-white px-[32px] py-[16px] rounded-lg hover:bg-green-700">Read More</a>
    </div>
  </section>

  <!-- Blog Section -->
  <section id="blog" class="relative bg-gray-50 h-[700px]">
    <h2 class="absolute top-[60px] left-1/2 transform -translate-x-1/2 text-[32px] font-bold">Latest Insights</h2>
    <div class="absolute top-[160px] left-1/2 transform -translate-x-1/2 grid grid-cols-3 gap-[40px]">
      <div class="bg-white shadow-lg w-[300px] h-[400px] p-[24px] rounded-lg">
        <img src="images/blog1.png" alt="Blog 1" class="w-full h-[180px] mb-[16px] rounded-lg">
        <h4 class="text-[20px] font-semibold mb-[12px]">Helping a local business reinvent itself</h4>
        <p class="text-[14px]">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
      </div>
      <div class="bg-white shadow-lg w-[300px] h-[400px] p-[24px] rounded-lg">
        <img src="images/blog2.png" alt="Blog 2" class="w-full h-[180px] mb-[16px] rounded-lg">
        <h4 class="text-[20px] font-semibold mb-[12px]">How to design your site footer like we did</h4>
        <p class="text-[14px]">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
      </div>
      <div class="bg-white shadow-lg w-[300px] h-[400px] p-[24px] rounded-lg">
        <img src="images/blog3.png" alt="Blog 3" class="w-full h-[180px] mb-[16px] rounded-lg">
        <h4 class="text-[20px] font-semibold mb-[12px]">Caring is the new marketing</h4>
        <p class="text-[14px]">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="relative bg-gray-900 text-white h-[300px]">
    <div class="absolute top-[60px] left-[100px] grid grid-cols-4 gap-[60px]">
      <div>
        <img src="images/logo-white.png" alt="Neosert Logo" class="w-[120px] h-[40px] mb-[16px]">
        <p class="text-[